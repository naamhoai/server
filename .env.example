# ─── Database ───
# Dev: trỏ thẳng vào file SQLite của Excel_trainer
DATABASE_URL="file:../Excel_trainer/prisma/data.db"
# Prod (MySQL): thay provider trong prisma/schema.prisma thành "mysql"
# DATABASE_URL="mysql://user:password@host:3306/excel_trainer"

# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── SePay ───
# Lấy từ SePay dashboard → Cài đặt webhook → Secret key
SEPAY_WEBHOOK_SECRET=your_webhook_secret_here
# Lấy từ SePay dashboard → API token
SEPAY_API_TOKEN=your_sepay_api_token_here
# Thông tin tài khoản ngân hàng (fallback nếu DB chưa có)
SEPAY_BANK_NAME=Vietinbank
SEPAY_ACCOUNT_NUMBER=your_account_number
SEPAY_ACCOUNT_NAME=YOUR ACCOUNT NAME

# ─── Telegram (optional - thông báo admin khi có thanh toán) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Auto-update ───
# API key để upload release files (POST /update/upload)
ADMIN_API_KEY=change_this_to_a_random_secret
# GitHub (optional - dùng để proxy check version từ GitHub Releases)
GITHUB_OWNER=naamhoai
GITHUB_REPO=Excel-trainer-
GITHUB_TOKEN=
