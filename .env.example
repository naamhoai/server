# ─── Database ───
# Máy server chạy DB SQLite riêng, file nằm trong folder prisma/
DATABASE_URL="file:./data.db"

# ─── Server ───
PORT=
NODE_ENV=

# ─── JWT (PHẢI giống Excel_trainer để token dùng được cả 2 nơi) ───
JWT_SECRET=

# ─── SePay ───
SEPAY_WEBHOOK_SECRET=
SEPAY_API_TOKEN=
SEPAY_BANK_NAME=
SEPAY_BANK_CODE=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=

# ─── Email (gửi OTP đăng ký / quên mật khẩu) ───
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Telegram (thông báo admin khi có thanh toán) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Auto-update ───
ADMIN_API_KEY=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=